COMPOSE_PROJECT_NAME=cicd
CICD_VOLUME_DIR=

# Caddy
# Set to the domain name you expect users to use to access this in their browsers
CADDY_DOMAIN=cicd.com
# set to "tls internal" to use self-signed certs (useful if hit rate limit for letsencrypt). Unset to have domain properly looked up.
CADDY_TLS_MODE=tls internal